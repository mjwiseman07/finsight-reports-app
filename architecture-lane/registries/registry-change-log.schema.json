{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advisacor.com/schemas/registry-change-log-entry/v1",
  "title": "RegistryChangeLogEntry",
  "description": "Phase 42.7A.5 — forward-only registry change log entry (11 required sections).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "heading",
    "commitSha",
    "author",
    "reviewer",
    "changeClass",
    "affectedFiles",
    "affectedTenantPopulation",
    "rationale",
    "citationSource",
    "riskImpact",
    "verification",
    "founderAttestation"
  ],
  "properties": {
    "heading": {
      "type": "string",
      "pattern": "^\\[\\d{4}-\\d{2}-\\d{2}\\].+"
    },
    "commitSha": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "const": "mwiseman@advisacor.com" },
    "changeClass": {
      "type": "string",
      "enum": ["add", "modify", "deprecate", "remove"]
    },
    "affectedFiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "affectedTenantPopulation": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rationale": { "type": "string", "minLength": 1 },
    "citationSource": {
      "type": "object",
      "required": ["sourceName", "urlOrHandle"],
      "properties": {
        "sourceName": { "type": "string", "minLength": 1 },
        "urlOrHandle": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "riskImpact": {
      "type": "object",
      "required": ["soc1Controls", "soc2Tscs", "hipaaSafeguards"],
      "properties": {
        "soc1Controls": { "type": "array", "items": { "type": "string" } },
        "soc2Tscs": { "type": "array", "items": { "type": "string" } },
        "hipaaSafeguards": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["verifiersRerun", "cumulativeTestCount"],
      "properties": {
        "verifiersRerun": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cumulativeTestCount": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "founderAttestation": {
      "type": "object",
      "required": ["signedBy", "attestedAt"],
      "properties": {
        "signedBy": { "type": "string", "const": "mwiseman@advisacor.com" },
        "attestedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "statement": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
