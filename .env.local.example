# Local development Supabase configuration.
# Use development or staging values only. Do not place production secrets here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Temporary read-only Postgres URL for live schema verification.
# Do not use SUPABASE_SERVICE_ROLE_KEY for Cursor verification.
SUPABASE_READONLY_DATABASE_URL=

# Optional local development/test integrations.
# Use development, staging, or test-mode values only.
OPENAI_API_KEY=
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Close packet renderer (Doc C).
# Base URL Puppeteer targets when generating the PDF from the HTML packet view.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-side bearer token Puppeteer sends on x-render-token to bypass auth for
# ?pdfMode=1 renders. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_RENDER_TOKEN=
# Supabase storage bucket for rendered close packet PDFs.
POSTMARK_INBOUND_WEBHOOK_SECRET=
INTAKE_ADDRESS_TOKEN_SECRET=

# --- Cloudflare Turnstile (CAPTCHA on auth surfaces) ---
# Sitekey is PUBLIC — safe to expose to the browser via NEXT_PUBLIC_ prefix.
# Secret goes into Supabase Dashboard → Auth → Bot & Abuse Protection, NOT into env.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
